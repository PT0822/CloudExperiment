FROM apache/spark:3.5.1-python3

# The SparkApplication in Appendix B loads this file through
# local:///opt/spark/work/analysis.py, so the analysis code must be baked into
# the submitted PySpark image rather than referenced from the host filesystem.
WORKDIR /opt/spark/work
COPY spark/analysis.py /opt/spark/work/analysis.py

USER 185
